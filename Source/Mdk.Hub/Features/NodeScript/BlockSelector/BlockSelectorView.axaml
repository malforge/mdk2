<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:Mdk.Hub.Features.NodeScript.BlockSelector"
             xmlns:selector="clr-namespace:Mdk.Hub.Features.NodeScript.Selector"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="Mdk.Hub.Features.NodeScript.BlockSelector.BlockSelectorView"
             x:DataType="local:BlockSelectorViewModel"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">

    <UserControl.Styles>
        <!-- Strip default selection/hover chrome from block grid items -->
        <Style Selector="ListBox.block-grid > ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      Padding="{TemplateBinding Padding}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                </ControlTemplate>
            </Setter>
        </Style>

        <!-- Block cell default -->
        <Style Selector="Border.block-cell">
            <Setter Property="Background" Value="{StaticResource BackgroundCardBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Margin" Value="4" />
        </Style>

        <!-- Block cell hover -->
        <Style Selector="Border.block-cell:pointerover">
            <Setter Property="Background" Value="{StaticResource BackgroundCardHoverBrush}" />
        </Style>

        <!-- Block cell selected -->
        <Style Selector="Border.block-cell.selected">
            <Setter Property="BorderBrush" Value="{StaticResource BorderAccentBrush}" />
        </Style>
    </UserControl.Styles>

    <selector:SelectorOverlayView x:Name="Selector"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch">

        <!-- Header filter: specific-block toggle -->
        <selector:SelectorOverlayView.FilterContent>
            <CheckBox Content="Specific block"
                      IsChecked="{Binding IsSpecificBlock, Mode=TwoWay}"
                      IsVisible="{Binding CanToggleTypeOnly}"
                      VerticalAlignment="Center" />
        </selector:SelectorOverlayView.FilterContent>

        <!-- Items panel: wrap grid for blocks -->
        <selector:SelectorOverlayView.ItemsPanel>
            <ItemsPanelTemplate>
                <WrapPanel />
            </ItemsPanelTemplate>
        </selector:SelectorOverlayView.ItemsPanel>

        <!-- Item template: 110×110 icon cell -->
        <selector:SelectorOverlayView.ItemTemplate>
            <DataTemplate DataType="local:BlockItem">
                <Border Classes="block-cell"
                        Classes.selected="{Binding $parent[ListBoxItem].IsSelected}"
                        Width="110"
                        Height="110"
                        ToolTip.Tip="{Binding DisplayName}">
                    <Grid>
                        <!-- Icon fills entire cell; placeholder shown until loaded -->
                        <Border Background="{StaticResource BackgroundSecondaryBrush}"
                                CornerRadius="2" />
                        <Image Source="{Binding Icon}"
                               Stretch="UniformToFill"
                               Margin="8"
                               IsVisible="{Binding Icon, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        <!-- Text at bottom, no scrim -->
                        <TextBlock Text="{Binding DisplayName}"
                                   FontSize="11"
                                   Padding="4,0,4,4"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Bottom" />
                        <!-- Upper-right: grid size indicator — only meaningful in specific-block mode -->
                        <Path HorizontalAlignment="Right"
                              VerticalAlignment="Top"
                              Margin="0,4,4,0"
                              Fill="{StaticResource ForegroundMutedBrush}"
                              IsVisible="{Binding $parent[ListBox].((local:BlockSelectorViewModel)DataContext).IsSpecificBlock}"
                              Data="{Binding IsLargeGrid, Converter={x:Static local:GridSizeGeometryConverter.Instance}}" />
                    </Grid>
                </Border>
            </DataTemplate>
        </selector:SelectorOverlayView.ItemTemplate>

    </selector:SelectorOverlayView>

</UserControl>

