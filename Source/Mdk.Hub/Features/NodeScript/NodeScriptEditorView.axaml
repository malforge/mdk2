<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:nodeScript="clr-namespace:Mdk.Hub.Features.NodeScript"
             xmlns:nodes="clr-namespace:Mdk.Hub.Features.NodeScript.Nodes"
             xmlns:controls="clr-namespace:NodifyM.Avalonia.Controls;assembly=NodifyM.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="Mdk.Hub.Features.NodeScript.NodeScriptEditorView"
             x:DataType="nodeScript:NodeScriptEditorViewModel">

    <UserControl.Styles>
        <StyleInclude Source="NodeEditorStyles.axaml" />

        <!-- Overlay blur effect -->
        <Style Selector="Grid.main-canvas.has-overlays">
            <Setter Property="IsEnabled" Value="False" />
            <Setter Property="Opacity" Value="0.5" />
            <Setter Property="Effect">
                <Setter.Value>
                    <BlurEffect Radius="5" />
                </Setter.Value>
            </Setter>
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>
    </UserControl.Styles>

    <Grid>
        <!-- Main Canvas -->
        <Grid x:Name="MainCanvas"
              Classes="main-canvas"
              Classes.has-overlays="{Binding HasOverlays}">

            <!-- Test button -->
            <Button Content="Test Block Selector"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="10"
                    Command="{Binding TestBlockSelectorCommand}"
                    ZIndex="100" />

            <!-- NodifyEditor Canvas -->
            <controls:NodifyEditor
                x:Name="EditorCanvas"
                PointerPressed="OnCanvasPointerPressed"
                ItemsSource="{Binding Nodes}"
                Connections="{Binding Connections}"
                Zoom="{Binding Zoom, Mode=TwoWay}">

                <!-- Grid Lines -->
                <controls:NodifyEditor.GridLineTemplate>
                    <DataTemplate>
                        <controls:LargeGridLine
                            Width="{Binding $parent[controls:NodifyEditor].Bounds.Width}"
                            Height="{Binding $parent[controls:NodifyEditor].Bounds.Height}"
                            OffsetX="{Binding $parent[controls:NodifyEditor].OffsetX}"
                            OffsetY="{Binding $parent[controls:NodifyEditor].OffsetY}"
                            Zoom="{Binding $parent[controls:NodifyEditor].Zoom}"
                            Spacing="30"
                            Thickness="0.5"
                            Brush="{StaticResource BorderSubtleBrush}"
                            ZIndex="-2" />
                    </DataTemplate>
                </controls:NodifyEditor.GridLineTemplate>

                <!-- Node Template -->
                <controls:NodifyEditor.ItemTemplate>
                    <DataTemplate DataType="nodes:BlocksNodeViewModel">
                        <controls:Node Location="{Binding Location, Mode=TwoWay}"
                                       Classes="blocks-node">
                            <controls:Node.Header>
                                <Button Command="{Binding ToggleExpandCommand}"
                                        Classes="node-header-toggle"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Text="{Binding Title}"
                                                   Classes="caption semibold node-header"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding ChevronGlyph}"
                                                   Classes="caption node-chevron-glyph"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Button>
                            </controls:Node.Header>

                            <!-- Collapsed: filter summary -->
                            <Panel>
                                <TextBlock IsVisible="{Binding !IsExpanded}"
                                           Text="{Binding Summary}"
                                           Classes="caption node-content" />

                                <!-- Expanded: inline editor -->
                                <StackPanel IsVisible="{Binding IsExpanded}"
                                            Spacing="3"
                                            Margin="0 4 0 0"
                                            MinWidth="180">
                                    <Button Content="{Binding BlockTypeDisplay}"
                                            Command="{Binding BrowseBlockTypeCommand}"
                                            Classes="node-type-picker"
                                            HorizontalAlignment="Stretch" />
                                    <TextBox Text="{Binding Pattern, Mode=TwoWay}"
                                             Watermark="Name pattern…"
                                             Classes="node-field"
                                             ToolTip.Tip="Filter by block name. Supports wildcards: * matches any characters, ? matches one. E.g. [Reactor]* matches all blocks whose name starts with [Reactor]." />
                                    <TextBox Text="{Binding GroupName, Mode=TwoWay}"
                                             Watermark="Group name…"
                                             Classes="node-field"
                                             ToolTip.Tip="Filter by block group name. Supports wildcards: * matches any characters, ? matches one. E.g. Power* matches all groups whose name starts with Power." />
                                    <TextBox Text="{Binding CustomDataSection, Mode=TwoWay}"
                                             Watermark="INI section…"
                                             Classes="node-field"
                                             ToolTip.Tip="Filter blocks by the presence of a specific INI section in their Custom Data. Supports wildcards: * matches any characters, ? matches one. E.g. Config* matches blocks that have any section starting with Config." />
                                    <TextBlock IsVisible="{Binding HasNoFilters}"
                                               Text="⚠ Matches all blocks"
                                               Classes="caption node-warning" />
                                </StackPanel>
                            </Panel>
                        </controls:Node>
                    </DataTemplate>
                </controls:NodifyEditor.ItemTemplate>

            </controls:NodifyEditor>

            <!-- Empty State Hint -->
            <TextBlock Text="Right Click to Start"
                       Classes="empty-state-hint"
                       IsVisible="{Binding !HasNodes}"
                       IsHitTestVisible="False" />
        </Grid>

        <!-- Overlay Layer (property editors, dialogs) -->
        <ItemsControl x:Name="OverlayPanel"
                      IsVisible="{Binding HasOverlays}"
                      Focusable="True"
                      ItemsSource="{Binding OverlayViews}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid Background="{StaticResource BackgroundOverlayBrush}" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>
    </Grid>

</UserControl>