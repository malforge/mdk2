<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:nodeScript="clr-namespace:Mdk.Hub.Features.NodeScript"
             xmlns:nodes="clr-namespace:Mdk.Hub.Features.NodeScript.Nodes"
             xmlns:controls="clr-namespace:NodifyM.Avalonia.Controls;assembly=NodifyM.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="Mdk.Hub.Features.NodeScript.NodeScriptEditorView"
             x:DataType="nodeScript:NodeScriptEditorViewModel">

    <UserControl.Styles>
        <StyleInclude Source="NodeEditorStyles.axaml" />

        <!-- Overlay blur effect -->
        <Style Selector="Grid.main-canvas.has-overlays">
            <Setter Property="IsEnabled" Value="False" />
            <Setter Property="Opacity" Value="0.5" />
            <Setter Property="Effect">
                <Setter.Value>
                    <BlurEffect Radius="5" />
                </Setter.Value>
            </Setter>
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>
    </UserControl.Styles>

    <Grid>
        <!-- Main Canvas -->
        <Grid x:Name="MainCanvas"
              Classes="main-canvas"
              Classes.has-overlays="{Binding HasOverlays}">

            <!-- Test button -->
            <Button Content="Test Block Selector"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="10"
                    Command="{Binding TestBlockSelectorCommand}"
                    ZIndex="100" />

            <!-- NodifyEditor Canvas -->
            <controls:NodifyEditor
                x:Name="EditorCanvas"
                PointerPressed="OnCanvasPointerPressed"
                ItemsSource="{Binding Nodes}"
                Connections="{Binding Connections}"
                Zoom="{Binding Zoom, Mode=TwoWay}">

                <!-- Grid Lines -->
                <controls:NodifyEditor.GridLineTemplate>
                    <DataTemplate>
                        <controls:LargeGridLine
                            Width="{Binding $parent[controls:NodifyEditor].Bounds.Width}"
                            Height="{Binding $parent[controls:NodifyEditor].Bounds.Height}"
                            OffsetX="{Binding $parent[controls:NodifyEditor].OffsetX}"
                            OffsetY="{Binding $parent[controls:NodifyEditor].OffsetY}"
                            Zoom="{Binding $parent[controls:NodifyEditor].Zoom}"
                            Spacing="30"
                            Thickness="0.5"
                            Brush="{StaticResource BorderSubtleBrush}"
                            ZIndex="-2" />
                    </DataTemplate>
                </controls:NodifyEditor.GridLineTemplate>

                <!-- Node Template -->
                <controls:NodifyEditor.ItemTemplate>
                    <DataTemplate DataType="nodes:BlocksNodeViewModel">
                        <controls:Node Location="{Binding Location, Mode=TwoWay}"
                                       Classes="blocks-node">
                            <controls:Node.Header>
                                <TextBlock Text="{Binding Title}"
                                           Classes="caption semibold node-header"
                                           Background="Transparent"
                                           PointerPressed="OnNodeContentPointerPressed" />
                            </controls:Node.Header>

                            <StackPanel Spacing="4"
                                        Background="Transparent"
                                        PointerPressed="OnNodeContentPointerPressed">
                                <TextBlock Text="{Binding Pattern}"
                                           Classes="caption node-content" />
                                <TextBlock Text="{Binding BlockType, StringFormat='Type: {0}'}"
                                           Classes="caption node-meta" />
                            </StackPanel>
                        </controls:Node>
                    </DataTemplate>
                </controls:NodifyEditor.ItemTemplate>

            </controls:NodifyEditor>

            <!-- Empty State Hint -->
            <TextBlock Text="Right Click to Start"
                       Classes="empty-state-hint"
                       IsVisible="{Binding !HasNodes}"
                       IsHitTestVisible="False" />

            <!-- Add Node Menu Popup -->
            <Popup IsOpen="{Binding IsAddNodeMenuOpen}"
                   PlacementTarget="{Binding $parent[UserControl]}"
                   IsLightDismissEnabled="True"
                   Placement="Pointer">
                <nodeScript:AddNodeMenuView DataContext="{Binding AddNodeMenu}" />
            </Popup>
        </Grid>

        <!-- Overlay Layer (property editors, dialogs) -->
        <ItemsControl IsVisible="{Binding HasOverlays}"
                      ItemsSource="{Binding OverlayViews}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid Background="{StaticResource BackgroundOverlayBrush}" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>
    </Grid>

</UserControl>