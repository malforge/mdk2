<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:nodeScript="clr-namespace:Mdk.Hub.Features.NodeScript"
             xmlns:nodes="clr-namespace:Mdk.Hub.Features.NodeScript.Nodes"
             xmlns:controls="clr-namespace:NodifyM.Avalonia.Controls;assembly=NodifyM.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="Mdk.Hub.Features.NodeScript.NodeScriptEditorView"
             x:DataType="nodeScript:NodeScriptEditorViewModel">

    <UserControl.DataTemplates>
        <DataTemplate DataType="nodes:BlocksNodeViewModel">
            <controls:Node Location="{Binding Location, Mode=TwoWay}"
                           Classes="complex-node"
                           Output="{Binding Outputs}">
                <nodes:BlocksNodeView />
            </controls:Node>
        </DataTemplate>
        <DataTemplate DataType="nodes:CombineNodeViewModel">
            <controls:Node Location="{Binding Location, Mode=TwoWay}"
                           Classes="simple-node"
                           Input="{Binding Inputs}"
                           Output="{Binding Outputs}">
                <nodes:CombineNodeView />
            </controls:Node>
        </DataTemplate>
    </UserControl.DataTemplates>

    <UserControl.Styles>
        <StyleInclude Source="NodeEditorStyles.axaml" />

        <!-- Overlay blur effect -->
        <Style Selector="Grid.main-canvas.has-overlays">
            <Setter Property="IsEnabled" Value="False" />
            <Setter Property="Opacity" Value="0.5" />
            <Setter Property="Effect">
                <Setter.Value>
                    <BlurEffect Radius="5" />
                </Setter.Value>
            </Setter>
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>
    </UserControl.Styles>

    <Grid>
        <!-- Main Canvas -->
        <Grid x:Name="MainCanvas"
              Classes="main-canvas"
              Classes.has-overlays="{Binding HasOverlays}">

            <!-- Test button -->
            <Button Content="Test Block Selector"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="10"
                    Command="{Binding TestBlockSelectorCommand}"
                    ZIndex="100" />

            <!-- NodifyEditor Canvas -->
            <controls:NodifyEditor
                x:Name="EditorCanvas"
                PointerPressed="OnCanvasPointerPressed"
                ItemsSource="{Binding Nodes}"
                Connections="{Binding Connections}"
                PendingConnection="{Binding PendingConnection}"
                DisconnectConnectorCommand="{Binding DisconnectConnectorCommand}"
                Zoom="{Binding Zoom, Mode=TwoWay}">

                <!-- Grid Lines -->
                <controls:NodifyEditor.GridLineTemplate>
                    <DataTemplate>
                        <controls:LargeGridLine
                            Width="{Binding $parent[controls:NodifyEditor].Bounds.Width}"
                            Height="{Binding $parent[controls:NodifyEditor].Bounds.Height}"
                            OffsetX="{Binding $parent[controls:NodifyEditor].OffsetX}"
                            OffsetY="{Binding $parent[controls:NodifyEditor].OffsetY}"
                            Zoom="{Binding $parent[controls:NodifyEditor].Zoom}"
                            Spacing="30"
                            Thickness="0.5"
                            Brush="{StaticResource BorderSubtleBrush}"
                            ZIndex="-2" />
                    </DataTemplate>
                </controls:NodifyEditor.GridLineTemplate>

                <!-- Connection line template -->
                <controls:NodifyEditor.ConnectionTemplate>
                    <DataTemplate DataType="nodeScript:ConnectionViewModel">
                        <controls:Connection Source="{Binding Source.Anchor}"
                                             Target="{Binding Target.Anchor}"
                                             DisconnectCommand="{Binding DisconnectCommand}"
                                             Stroke="{StaticResource ForegroundAccentBrush}"
                                             StrokeThickness="1.5"
                                             ToolTip.Tip="Alt+Click to remove this connection." />
                    </DataTemplate>
                </controls:NodifyEditor.ConnectionTemplate>

                <!-- Pending (in-progress) connection preview -->
                <controls:NodifyEditor.PendingConnectionTemplate>
                    <DataTemplate DataType="nodeScript:PendingConnectionViewModel">
                        <controls:PendingConnection StartedCommand="{Binding StartCommand}"
                                                    CompletedCommand="{Binding FinishCommand}"
                                                    Stroke="{StaticResource ForegroundAccentBrush}"
                                                    StrokeThickness="1.5"
                                                    StrokeDashArray="4,2" />
                    </DataTemplate>
                </controls:NodifyEditor.PendingConnectionTemplate>

            </controls:NodifyEditor>

            <!-- Empty State Hint -->
            <TextBlock Text="Right Click to Start"
                       Classes="empty-state-hint"
                       IsVisible="{Binding !HasNodes}"
                       IsHitTestVisible="False" />
        </Grid>

        <!-- Overlay Layer (property editors, dialogs) -->
        <ItemsControl x:Name="OverlayPanel"
                      IsVisible="{Binding HasOverlays}"
                      Focusable="True"
                      ItemsSource="{Binding OverlayViews}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid Background="{StaticResource BackgroundOverlayBrush}" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>
    </Grid>

</UserControl>

